# AI接口统一处理模块 - 环境变量配置示例

# ==================== OpenAI 服务配置 ====================
AI_SERVICE_OPENAI_API_KEY=sk-xxx
AI_SERVICE_OPENAI_BASE_URL=https://api.openai.com/v1
AI_SERVICE_OPENAI_TIMEOUT=30000

# ==================== Stability AI 服务配置 ====================
AI_SERVICE_STABILITY_API_KEY=sk-xxx
AI_SERVICE_STABILITY_BASE_URL=https://api.stability.ai/v1
AI_SERVICE_STABILITY_TIMEOUT=30000

# ==================== Replicate 服务配置 ====================
AI_SERVICE_REPLICATE_API_TOKEN=r8_xxx
AI_SERVICE_REPLICATE_BASE_URL=https://api.replicate.com/v1
AI_SERVICE_REPLICATE_TIMEOUT=60000

# ==================== Google Gemini 服务配置 ====================
AI_SERVICE_GEMINI_API_KEY=xxx
AI_SERVICE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
AI_SERVICE_GEMINI_TIMEOUT=30000

# ==================== Anthropic 服务配置 ====================
AI_SERVICE_ANTHROPIC_API_KEY=sk-ant-xxx
AI_SERVICE_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AI_SERVICE_ANTHROPIC_TIMEOUT=30000

# ==================== Midjourney 服务配置 ====================
AI_SERVICE_MIDJOURNEY_API_KEY=xxx
AI_SERVICE_MIDJOURNEY_BASE_URL=https://api.midjourney.com/v1
AI_SERVICE_MIDJOURNEY_TIMEOUT=60000

# ==================== Skyreels 服务配置 ====================
AI_SERVICE_SKYREELS_API_KEY=xxx
AI_SERVICE_SKYREELS_BASE_URL=https://api-gateway.skyreels.ai/api/v1
AI_SERVICE_SKYREELS_TIMEOUT=120000

# ==================== LTX 服务配置 ====================
AI_SERVICE_LTX_API_KEY=xxx
AI_SERVICE_LTX_BASE_URL=https://api.ltx.video
AI_SERVICE_LTX_TIMEOUT=300000

# ==================== 火山引擎(Volcengine) 服务配置 ====================
AI_SERVICE_VOLCENGINE_API_KEY=xxx
AI_SERVICE_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_SERVICE_VOLCENGINE_TIMEOUT=120000

# ==================== Mureka 服务配置 ====================
AI_SERVICE_MUREKA_API_KEY=xxx
AI_SERVICE_MUREKA_BASE_URL=https://api.mureka.ai/v1
AI_SERVICE_MUREKA_TIMEOUT=120000

# ==================== 日志配置 ====================
AI_SERVICE_LOG_LEVEL=info
AI_SERVICE_LOG_FORMAT=json
