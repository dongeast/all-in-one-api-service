{
  "name": "all-in-one-api-service",
  "version": "1.0.0",
  "description": "统一的AI接口处理模块",
  "main": "index.js",
  "module": "index.esm.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.esm.js",
      "types": "./index.d.ts"
    },
    "./services": "./src/services/index.js",
    "./apis": "./src/apis/index.js",
    "./apis/ltx": "./src/apis/ltx/index.js",
    "./apis/volcengine": "./src/apis/volcengine/index.js",
    "./apis/skyreels": "./src/apis/skyreels/index.js",
    "./apis/mureka": "./src/apis/mureka/index.js",
    "./params": "./src/params/index.js",
    "./utils": "./src/utils/index.js",
    "./config": "./src/config/index.js",
    "./constants": "./src/constants/index.js",
    "./registry": "./src/registry/index.js",
    "./query-service": "./src/services/query-service.js"
  },
  "files": [
    "index.js",
    "index.esm.js",
    "index.d.ts",
    "src/**/*"
  ],
  "scripts": {
    "test": "node tests/run-tests.js --tests",
    "test:all": "node tests/run-tests.js --all",
    "test:examples": "node tests/run-tests.js --examples",
    "test:stream": "node tests/run-tests.js stream-basic",
    "test:list": "node tests/run-tests.js --list",
    "lint": "eslint src/",
    "build": "echo \"No build step required for CommonJS module\"",
    "setup": "node scripts/setup-config.js"
  },
  "keywords": [
    "ai",
    "image-generation",
    "text-generation",
    "video-generation",
    "ltx",
    "skyreels",
    "mureka",
    "volcengine",
    "music-generation",
    "3d-generation",
    "audio-generation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "optionalDependencies": {
    "node-fetch": "^2.6.7"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
