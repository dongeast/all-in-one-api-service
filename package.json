{
  "name": "all-in-one-api-service",
  "version": "1.0.0",
  "description": "统一的AI接口处理模块",
  "main": "index.js",
  "module": "index.esm.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.esm.js",
      "types": "./index.d.ts"
    },
    "./services": "./src/services/index.js",
    "./apis": "./src/apis/index.js",
    "./params": "./src/params/index.js",
    "./utils": "./src/utils/index.js",
    "./config": "./src/config/index.js",
    "./constants": "./src/constants/index.js",
    "./registry": "./src/registry/index.js",
    "./query-service": "./src/services/query-service.js"
  },
  "browser": {
    "./src/config/config-loader.js": "./browser/config/config-loader.js",
    "./src/config/config-manager.js": "./browser/config/config-manager.js",
    "./src/utils/env-parser.js": "./browser/utils/env-parser.js",
    "./src/utils/logger.js": "./browser/utils/logger.js",
    "./src/locales/index.js": "./browser/locales/index.js",
    "./index.js": "./browser/index.js"
  },
  "files": [
    "index.js",
    "index.esm.js",
    "index.d.ts",
    "src/**/*",
    "browser/**/*"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "npm run test:coverage",
    "test:examples": "node tests/run-tests.js --examples",
    "test:stream": "node tests/run-tests.js stream-basic",
    "test:list": "node tests/run-tests.js --list",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json}\"",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "setup": "node scripts/setup-config.js"
  },
  "keywords": [
    "ai",
    "image-generation",
    "text-generation",
    "video-generation",
    "ltx",
    "skyreels",
    "mureka",
    "volcengine",
    "music-generation",
    "3d-generation",
    "audio-generation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "optionalDependencies": {
    "node-fetch": "^2.6.7"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
