{
  "version": "1.0",
  "defaultProvider": "openai",
  "providers": {
    "skyreels": {
      "apiKey": "YOUR_SKYREELS_API_KEY",
      "baseURL": "https://api-gateway.skyreels.ai/api/v1",
      "timeout": 120000,
      "retryCount": 3,
      "retryDelay": 2000
    },
    "ltx": {
      "apiKey": "YOUR_LTX_API_KEY",
      "baseURL": "https://api.ltx.video",
      "timeout": 300000,
      "retryCount": 3,
      "retryDelay": 2000
    },
    "volcengine": {
      "apiKey": "YOUR_VOLCENGINE_API_KEY",
      "baseURL": "https://ark.cn-beijing.volces.com/api/v3",
      "timeout": 120000,
      "retryCount": 3,
      "retryDelay": 2000
    },
    "mureka": {
      "apiKey": "YOUR_MUREKA_API_KEY",
      "baseURL": "https://api.mureka.ai/v1",
      "timeout": 120000,
      "retryCount": 3,
      "retryDelay": 2000
    },
    "vidu": {
      "apiKey": "YOUR_VIDU_API_KEY",
      "baseURL": "https://api.vidu.cn",
      "timeout": 300000,
      "retryCount": 3,
      "retryDelay": 2000
    }
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
